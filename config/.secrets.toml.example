# =============================================================================
# Trading Bot Secrets - LOCAL DEVELOPMENT ONLY
# =============================================================================
# This file is ONLY for local development when Azure is not configured.
#
# FOR PRODUCTION: Use Azure Key Vault
#   - Store secrets with names like: alpaca-api-key, alpaca-secret-key
#   - Set AZURE_KEYVAULT_URL environment variable
#
# FOR LOCAL DEV: Either use this file OR environment variables:
#   - Copy this to .secrets.toml and fill in values
#   - Or set environment variables: ALPACA_API_KEY, ALPACA_SECRET_KEY, etc.
#
# NEVER commit .secrets.toml to version control!
# =============================================================================

[default.api.webhook]
# Webhook secret for TradingView signal authentication
# Azure Key Vault name: webhook-secret
secret = ""

[default.ngrok]
# ngrok auth token for exposing local webhook server
# Azure Key Vault name: ngrok-auth-token
auth_token = ""

# -----------------------------------------------------------------------------
# ALPACA CREDENTIALS
# -----------------------------------------------------------------------------
# Azure Key Vault names: alpaca-api-key, alpaca-secret-key

[default.api.alpaca]
api_key = ""      # Your Alpaca API key
secret_key = ""   # Your Alpaca secret key

# -----------------------------------------------------------------------------
# TASTYTRADE CREDENTIALS (OAuth)
# -----------------------------------------------------------------------------
# Azure Key Vault names: tastytrade-client-secret, tastytrade-refresh-token

[default.api.tastytrade]
client_secret = ""   # OAuth client secret
refresh_token = ""   # OAuth refresh token (never expires)
account_id = ""      # Your account ID

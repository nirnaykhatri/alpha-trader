# =============================================================================
# Trading Bot Secrets Configuration
# =============================================================================
# This file contains sensitive credentials. NEVER commit to version control.
#
# STRUCTURE:
# - [default] section: Shared settings used by ALL environments
# - [demo] section: Paper trading credentials (overrides default)
# - [live] section: Live trading credentials (overrides default)
#
# The active environment is set via: TRADING_BOT_ENV=demo|live
# =============================================================================

# -----------------------------------------------------------------------------
# DEFAULT (Shared) Settings
# -----------------------------------------------------------------------------
# These apply to all environments unless overridden below.

[default.api.webhook]
# Webhook secret for TradingView signal authentication (not broker-specific)
secret = ""

[default.ngrok]
# ngrok auth token for exposing local webhook server
auth_token = ""

[default.monitoring.alerts.email]
smtp_server = ""
username = ""
password = ""
from_address = ""

[default.monitoring.alerts.slack]
webhook_url = ""

# -----------------------------------------------------------------------------
# DEMO (Paper Trading) Credentials
# -----------------------------------------------------------------------------
# Used when TRADING_BOT_ENV=demo (default)

[demo.api.alpaca]
api_key = ""      # Paper trading API key from Alpaca
secret_key = ""   # Paper trading secret key

[demo.api.tastytrade]
username = ""
password = ""
account_id = ""   # Sandbox account ID

# -----------------------------------------------------------------------------
# LIVE (Real Money) Credentials  
# -----------------------------------------------------------------------------
# Used when TRADING_BOT_ENV=live
# ⚠️  WARNING: These credentials trade with REAL MONEY!

[live.api.alpaca]
api_key = ""      # Live trading API key from Alpaca
secret_key = ""   # Live trading secret key

[live.api.tastytrade]
username = ""
password = ""
account_id = ""   # Production account ID

# =============================================================================
# Trading Bot Configuration - Environment Variables Example
# =============================================================================
# 
# CONFIGURATION STRATEGY (Azure-First):
# All configuration should be managed via Azure for production deployments,
# enabling runtime updates WITHOUT requiring redeployment.
#
# FOR PRODUCTION (Azure):
#   Secrets → Azure Key Vault (API keys, passwords)
#   Config  → Azure App Configuration (runtime settings, feature flags)
#
# FOR LOCAL DEVELOPMENT:
#   Copy this file to .env and set the required values
#   Or export variables directly in your shell
#
# PRECEDENCE (highest to lowest):
#   1. Azure Key Vault (secrets only)
#   2. Azure App Configuration (runtime config)
#   3. Environment variables (this file)
#   4. Default values from ConfigContract
#
# =============================================================================

# =============================================================================
# AZURE INFRASTRUCTURE (Required for Production)
# =============================================================================

# Azure Key Vault URL for secrets
# Format: https://<vault-name>.vault.azure.net
AZURE_KEYVAULT_URL=

# Azure App Configuration endpoint
# Format: https://<config-name>.azconfig.io
AZURE_APP_CONFIGURATION_ENDPOINT=

# =============================================================================
# DATABASE (Cosmos DB) - Required
# =============================================================================

# Cosmos DB endpoint (Required)
# Find in Azure Portal > Cosmos DB > Keys
AZURE_COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/

# Cosmos DB database name (Required)
AZURE_COSMOS_DATABASE=trading_bot

# Cosmos DB key (Optional - use Managed Identity in production)
# AZURE_COSMOS_KEY=

# Cosmos DB settings
COSMOS_THROUGHPUT_RU=400
COSMOS_CONSISTENCY_LEVEL=Session

# =============================================================================
# BROKER CREDENTIALS - At least one broker required
# =============================================================================

# --- Alpaca (Recommended for US Equities) ---
# Get keys from: https://app.alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_TIMEOUT=30

# --- Tastytrade (Alternative) ---
# Generate from Tastytrade OAuth flow
TASTYTRADE_CLIENT_SECRET=
TASTYTRADE_REFRESH_TOKEN=
TASTYTRADE_ACCOUNT_ID=

# =============================================================================
# WEBHOOK / API SERVER
# =============================================================================

# Webhook server configuration
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_SECURITY_ENABLED=true

# Webhook secret for TradingView signal authentication
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# =============================================================================
# TRADING PARAMETERS
# =============================================================================

# Enable paper trading (recommended for testing)
TRADING_PAPER_MODE=true

# Default order type
TRADING_ORDER_TYPE=limit

# Maximum trades per day
TRADING_MAX_DAILY_TRADES=50

# Default broker to use
DEFAULT_BROKER=alpaca

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=json

# Enable monitoring and health checks
MONITORING_ENABLED=true

# Environment name
ENVIRONMENT=development

# =============================================================================
# QUICK START GUIDE
# =============================================================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Set required values:
#    - AZURE_COSMOS_ENDPOINT
#    - AZURE_COSMOS_DATABASE
#    - At least one broker (Alpaca or Tastytrade)
#
# 3. Validate configuration:
#    python -m src.config.config_contract --check
#
# 4. For production, migrate to Azure:
#    - Store secrets in Azure Key Vault
#    - Store config in Azure App Configuration
#    - Set AZURE_KEYVAULT_URL and AZURE_APP_CONFIGURATION_ENDPOINT
#
# =============================================================================
